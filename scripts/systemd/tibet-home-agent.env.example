# TIBET Home Agent — environment file
# Install to: /etc/default/tibet-home-agent  (chmod 600 root:root)
#
# This file is read by the systemd unit. Restart after edits:
#   sudo systemctl restart tibet-home-agent

# ─── Required ──────────────────────────────────────────────────────────────

# Your home-agent .aint sub-domain (without the .aint suffix).
HOME_AGENT_AINT=home.vandemeent

# Session token from your .aint claim flow.
# Pull the active token with:
#   python3 -c "import json,datetime; \
#     s=json.load(open('/srv/jtel-stack/brain_api/data/ainternet_sessions.json')); \
#     [print(t) for t,v in s.items() if v['domain']=='vandemeent' \
#       and datetime.datetime.fromisoformat(v['expires_at'])>datetime.datetime.now()]"
HOME_AGENT_TOKEN=

# Brain API URL. Use loopback when daemon and brain are on the same host.
BRAIN_URL=http://localhost:8000

# ─── Provider ──────────────────────────────────────────────────────────────

# v0.2 — uses the local Claude Pro/Max CLI session, no API key needed here.
# Other options: 'echo' (test loopback), 'gemini', 'anthropic', 'openai'.
HOME_AGENT_PROVIDER=claude_cli

# ─── claude_cli tunables (only used when provider=claude_cli) ──────────────

HOME_AGENT_MODEL=claude-sonnet-4-6
# HOME_AGENT_CLAUDE_MODE=simple    # 'simple' (stdin pipe, ~6s) or 'upip' (work-dir, ~9-15s, rich payloads)
# HOME_AGENT_CLAUDE_CLI=/usr/bin/claude
# HOME_AGENT_TIMEOUT=25
# HOME_AGENT_MAX_TURNS=3            # only relevant in upip mode

# ─── Optional ──────────────────────────────────────────────────────────────

# Per-agent I-Poll pull token. If set, used alongside the Bearer session.
# HOME_AGENT_IPOLL_TOKEN=

# v0.1 provider keys — only set if HOME_AGENT_PROVIDER=gemini/anthropic/openai.
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Inbox poll interval (seconds). Lower = snappier, higher = less brain load.
POLL_INTERVAL=2
